<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>SwiftPDF</title>
    
    <link rel="stylesheet" href="./bootstrap.min.css">
    
    <style>
        /* Base Premium Dark Theme Variables */
        :root {
            --bg-dark: #121212;
            --bg-surface: #1e1e1e;
            --accent-teal: #00f2fe;
            --text-main: #e0e0e0;
            --text-muted: #a0a0a0;
            /* Safe Area Insets for Mobile Notches */
            --safe-top: env(safe-area-inset-top, 0px);
            --safe-bottom: env(safe-area-inset-bottom, 0px);
        }

        /* Prevent system scrolling/pinching on mobile webview */
        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            background-color: var(--bg-dark);
            color: var(--text-main);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            user-select: none;
            -webkit-user-select: none;
        }

        /* Full Screen App Layout Wrapper */
        .app-container {
            display: flex;
            flex-direction: column;
            width: 100%;
            height: 100%;
        }

        /* Header - Protected against Notches / Front Cameras */
        .app-header {
            background-color: var(--bg-surface);
            padding-top: calc(var(--safe-top) + 12px);
            padding-bottom: 12px;
            padding-left: 16px;
            padding-right: 16px;
            border-bottom: 1px solid #2d2d2d;
            z-index: 10;
        }

        .app-title {
            font-size: 1.15rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            color: #fff;
        }
        
        .accent-text {
            color: var(--accent-teal);
        }

        /* Scrollable Content Area for PDF Display */
        .app-content {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            padding: 15px;
            -webkit-overflow-scrolling: touch; /* Smooth iOS momentum scrolling */
        }

        /* Centered Canvas Container */
        .pdf-viewport {
            width: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            border-radius: 8px;
            overflow: hidden;
            background: #000;
        }

        canvas {
            max-width: 100%;
            height: auto !important;
            display: block;
        }

        /* Bottom Status/Control Bar */
        .app-footer {
            background-color: var(--bg-surface);
            padding-bottom: calc(var(--safe-bottom) + 12px);
            padding-top: 12px;
            padding-left: 16px;
            padding-right: 16px;
            border-top: 1px solid #2d2d2d;
            font-size: 0.85rem;
            color: var(--text-muted);
            z-index: 10;
        }

        /* Premium Buttons */
        .btn-custom {
            background-color: #2a2a2a;
            color: #fff;
            border: 1px solid #3a3a3a;
            border-radius: 6px;
            font-weight: 500;
            transition: all 0.2s ease;
        }
        .btn-custom:active {
            background-color: var(--accent-teal);
            color: #121212;
            border-color: var(--accent-teal);
        }

        /* 2. App Loading/Splash Screen overlay */
        #splash-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background-color: var(--bg-dark);
            z-index: 9999;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            transition: opacity 0.5s ease-out, visibility 0.5s;
        }

        .spinner-neon {
            width: 50px;
            height: 50px;
            border: 3px solid rgba(0, 242, 254, 0.1);
            border-radius: 50%;
            border-top-color: var(--accent-teal);
            animation: spin 1s ease-in-out infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* 5. In-App Mobile Toast Notifications */
        .mobile-toast {
            position: fixed;
            bottom: calc(var(--safe-bottom) + 70px);
            left: 50%;
            transform: translateX(-50%) translateY(100px);
            background-color: #252525;
            color: #fff;
            padding: 12px 24px;
            border-radius: 30px;
            font-size: 0.9rem;
            box-shadow: 0 8px 24px rgba(0,0,0,0.4);
            border: 1px solid rgba(255,255,255,0.05);
            z-index: 2000;
            opacity: 0;
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), opacity 0.3s ease;
            pointer-events: none;
            white-space: nowrap;
        }
        .mobile-toast.show {
            transform: translateX(-50%) translateY(0);
            opacity: 1;
        }
        .mobile-toast.success { border-left: 4px solid var(--accent-teal); }
        .mobile-toast.error { border-left: 4px solid #ff4a4a; }

        /* Welcome Empty State Context */
        .empty-state {
            text-align: center;
            margin-top: auto;
            margin-bottom: auto;
            color: var(--text-muted);
        }
    </style>
</head>
<body>

    <div id="splash-screen">
        <div class="spinner-neon mb-3"></div>
        <h1 class="h5 fw-bold tracking-wide text-white">Swift<span class="accent-text">PDF</span></h1>
    </div>

    <div class="app-container">
        
        <header class="app-header d-flex justify-content-between align-items-center">
            <div class="app-title">Swift<span class="accent-text">PDF</span></div>
            <div>
                <input type="file" id="file-input" accept=".pdf" style="display: none;">
                <button class="btn btn-sm btn-custom px-3" onclick="document.getElementById('file-input').click()">
                    Open File
                </button>
            </div>
        </header>

        <main class="app-content" id="gesture-zone">
            <div id="empty-view" class="empty-state">
                <p class="mb-1 fw-semibold text-white">No Document Active</p>
                <small>Tap "Open File" to browse your device storage.</small>
            </div>
            <div class="pdf-viewport d-none" id="pdf-wrapper">
                <canvas id="pdf-canvas"></canvas>
            </div>
        </main>

        <footer class="app-footer d-flex justify-content-between align-items-center">
            <div id="file-name-display" class="text-truncate" style="max-width: 60%;">No file active</div>
            <div id="page-counter-display">Page: -- / --</div>
        </footer>

    </div>

    <div id="toast-notification" class="mobile-toast">Document Loaded Successfully!</div>

    <script src="./pdf.min.js"></script>
    <script src="./pdf.worker.min.js"></script>

    <script>
        // Set up local PDF.js worker reference path explicitly for offline sandboxing
        if (window['pdfjs-dist/build/pdf']) {
            pdfjsLib.GlobalWorkerOptions.workerSrc = './pdf.worker.min.js';
        }

        // Application State Management
        let pdfDoc = null;
        let pageNum = 1;
        let pageIsRendering = false;
        let pageNumPending = null;

        const canvas = document.getElementById('pdf-canvas');
        const ctx = canvas.getContext('2d');

        // Elements
        const fileInput = document.getElementById('file-input');
        const emptyView = document.getElementById('empty-view');
        const pdfWrapper = document.getElementById('pdf-wrapper');
        const fileNameDisplay = document.getElementById('file-name-display');
        const pageCounterDisplay = document.getElementById('page-counter-display');
        const splashScreen = document.getElementById('splash-screen');

        /* 2. Splash Screen Exiting Loop */
        window.addEventListener('DOMContentLoaded', () => {
            setTimeout(() => {
                splashScreen.style.opacity = '0';
                splashScreen.style.visibility = 'hidden';
            }, 2500);
        });

        /* 5. Custom Native Toast Alert Engine */
        function showToast(message, type = 'success') {
            const toast = document.getElementById('toast-notification');
            toast.innerText = message;
            toast.className = `mobile-toast show ${type}`;
            
            setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        /* Render Logic Engine for Canvas processing */
        function renderPage(num) {
            pageIsRendering = true;
            
            pdfDoc.getPage(num).then(page => {
                // Calculate scale strictly matching the hardware device viewport
                const viewport = page.getViewport({ scale: 1.5 });
                
                // Track standard device pixel ratio details for crisp text representation
                const outputScale = window.devicePixelRatio || 1;
                
                canvas.width = Math.floor(viewport.width * outputScale);
                canvas.height = Math.floor(viewport.height * outputScale);
                canvas.style.width = Math.floor(viewport.width) + "px";
                canvas.style.height = Math.floor(viewport.height) + "px";

                const transform = outputScale !== 1 ? [outputScale, 0, 0, outputScale, 0, 0] : null;

                const renderContext = {
                    canvasContext: ctx,
                    viewport: viewport,
                    transform: transform
                };

                page.render(renderContext).promise.then(() => {
                    pageIsRendering = false;
                    if (pageNumPending !== null) {
                        renderPage(pageNumPending);
                        pageNumPending = null;
                    }
                });

                // Update Bottom Navigation HUD
                pageCounterDisplay.innerText = `Page: ${num} / ${pdfDoc.numPages}`;
            });
        }

        function queueRenderPage(num) {
            if (pageIsRendering) {
                pageNumPending = num;
            } else {
                renderPage(num);
            }
        }

        // Navigation controls
        function prevPage() {
            if (pageNum <= 1) return;
            pageNum--;
            queueRenderPage(pageNum);
        }

        function nextPage() {
            if (pageNum >= pdfDoc.numPages) return;
            pageNum++;
            queueRenderPage(pageNum);
        }

        /* 3. Native Storage Access Processing */
        fileInput.addEventListener('change', (e) => {
            const file = e.target.files[0];
            if (!file) return;

            fileNameDisplay.innerText = file.name;

            const fileReader = new FileReader();
            fileReader.onload = function() {
                const typedarray = new Uint8Array(this.result);

                // Instantiating PDF.js library natively 
                pdfjsLib.getDocument(typedarray).promise.then(pdf => {
                    pdfDoc = pdf;
                    pageNum = 1;
                    
                    // Toggle Views UI
                    emptyView.classList.add('d-none');
                    pdfWrapper.classList.remove('d-none');
                    
                    renderPage(pageNum);
                    showToast("Document Loaded Successfully!", "success");
                }).catch(err => {
                    console.error(err);
                    showToast("Error processing PDF document.", "error");
                });
            };
            fileReader.readAsArrayBuffer(file);
        });

        /* 4. Native Touch Swipe Detection Module */
        let touchStartX = 0;
        let touchEndX = 0;
        const gestureZone = document.getElementById('gesture-zone');

        gestureZone.addEventListener('touchstart', e => {
            touchStartX = e.changedTouches[0].screenX;
        }, { passive: true });

        gestureZone.addEventListener('touchend', e => {
            touchEndX = e.changedTouches[0].screenX;
            handleSwipeGesture();
        }, { passive: true });

        function handleSwipeGesture() {
            const swipeThreshold = 60; // minimum required slide swipe size in px
            if (!pdfDoc) return;

            if (touchStartX - touchEndX > swipeThreshold) {
                // Swiped Left -> Load Next Page
                nextPage();
            } else if (touchEndX - touchStartX > swipeThreshold) {
                // Swiped Right -> Load Previous Page
                prevPage();
            }
        }
    </script>
</body>
</html>